rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /sessions/{sessionId} {
      // Anyone with the link can read a session.
      allow read: if true;

      // Create allowed only by authenticated user creating their own session doc.
      allow create: if request.auth != null && request.resource.data.owner == request.auth.uid;

      // Updates & deletes only by the recorded owner.
      allow update, delete: if request.auth != null && resource.data.owner == request.auth.uid;
    }
  }
}
