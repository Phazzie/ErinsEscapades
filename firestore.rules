rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /sessions/{sessionId} {
      // Anyone with the link can read a session.
      allow read: if true;

      // Create allowed only by authenticated user creating their own session doc.
      allow create: if request.auth != null && request.resource.data.owner == request.auth.uid;

  // Updates allowed by any authenticated user, but owner field must not change.
  allow update: if request.auth != null
        && request.resource.data.owner == resource.data.owner;

  // Deletes restricted to owner.
  allow delete: if request.auth != null && resource.data.owner == request.auth.uid;
    }
  }
}
